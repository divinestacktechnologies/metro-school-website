# Copy this file to .env and change these before deploying.
# The admin dashboard at /admin is protected by these credentials.
ADMIN_USER=admin
ADMIN_PASS=Admin@2619

# Most hosting providers set PORT automatically — you usually don't need to set this.
# PORT=3000

# URL of the school ERP's enquiry API endpoint. When a parent submits the
# admission enquiry form, it is saved here locally AND forwarded to this URL
# so it also shows up under the ERP's Admin Panel -> Admission Enquiries.
# For local testing with XAMPP (Apache on port 80):
ERP_ENQUIRY_URL=http://localhost/erp/api/save_enquiry.php
# Once live, change this to the ERP's real deployed URL, e.g.:
# ERP_ENQUIRY_URL=https://metropublicschool.in/erp/api/save_enquiry.php

